    "settings": {
      "code": "<script>(function(){var url='https://maxhair.cz/wp-content/uploads/2026/02/Layer0.png';function fix(){var h=document.querySelector('#brx-header,#main-header,header');if(!h)return;var links=h.querySelectorAll('a[href=\"/\"],a[href*=\"maxhair.cz/\"]');for(var i=0;i<links.length;i++){var a=links[i];if(a.closest('nav'))continue;var txt=(a.textContent||'').trim();if(txt.indexOf('MAX')>=0||txt.indexOf('HAIR')>=0||(!a.querySelector('img')&&txt.length<30)){var img=a.querySelector('img');if(img)img.src=url;else a.innerHTML='<img src=\"'+url+'\" alt=\"MaxHair\" style=\"height:40px;width:auto;max-height:50px\">';return}}}if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',fix);else fix();setTimeout(fix,300);setTimeout(fix,1000);})();</script>\n<script>(function(){var sectionId='brxe-reference_hero_section';if(!window.matchMedia('(max-width: 900px)').matches)return;function getSvhPx(){var d=document.createElement('div');d.style.cssText='height:100svh;position:absolute;top:-9999px;left:0;visibility:hidden;';document.body.appendChild(d);var h=d.offsetHeight;document.body.removeChild(d);return h;}function lockHero(){var section=document.getElementById(sectionId);var container=section?section.querySelector('.brxe-container'):null;var h=getSvhPx();if(section){section.style.height=h+'px';section.style.minHeight=h+'px';section.style.maxHeight=h+'px';}if(container){container.style.height=h+'px';container.style.minHeight=h+'px';container.style.maxHeight=h+'px';}}if(document.body)lockHero();if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',lockHero);else setTimeout(lockHero,0);setTimeout(lockHero,100);})();</script>\n<script>(function(){var d=document;if(!window.matchMedia('(max-width: 900px)').matches)return;function fix(){var section=d.getElementById('brxe-reference_hero_section');var container=d.getElementById('brxe-reference_hero_container');var code=d.getElementById('brxe-reference_hero_code');if(section){section.style.setProperty('background','#1A1A1A','important');section.style.setProperty('padding','0','important');section.style.setProperty('margin','0','important');}if(container){container.style.setProperty('background','#1A1A1A','important');container.style.setProperty('padding','0','important');container.style.setProperty('margin','0','important');}if(code){code.style.setProperty('background','transparent','important');code.style.setProperty('padding','0','important');code.style.setProperty('margin','0','important');}}function run(){fix();var t=0;var iv=setInterval(function(){fix();t+=200;if(t>=1500)clearInterval(iv);},200);}if(d.readyState==='loading')d.addEventListener('DOMContentLoaded',run);else run();})();</script>\n<!-- RESULTS HERO SECTION -->\n<section class=\"reference-hero-section\">\n  <div class=\"mh-hero-bg\">\n    <div class=\"mh-hero-overlay\"></div>\n    <video autoplay muted loop playsinline class=\"mh-hero-video\" poster=\"https://maxhair.cz/wp-content/uploads/2026/02/Layer0.png\">\n      <source src=\"https://mediumseagreen-gaur-406121.hostingersite.com/wp-content/uploads/2025/12/WhatsApp-Video-2025-12-13-at-14.56.52_6de6a47b.mp4\" type=\"video/mp4\">\n    </video>\n  </div>\n  <div class=\"reference-hero-content\">\n    <span class=\"mh-badge\">RESULTS</span>\n    <h1 class=\"hero-title\" style=\"color: #ffffff !important; -webkit-text-fill-color: #ffffff !important;\">Real results. Real reviews.</h1>\n    <div class=\"reference-hero-links\">\n      <a href=\"#reference-recenze\" class=\"reference-hero-pill\">Client reviews</a>\n      <a href=\"https://instagram.com/maxhair.cz\" class=\"reference-hero-pill reference-hero-pill-secondary\" target=\"_blank\" rel=\"noopener\">Follow us</a>\n    </div>\n  </div>\n</section>\n\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap');\n\n  :root {\n    --primary-gold: #E5C158;\n    --secondary-gold: #D4AF37;\n    --dark-gray: #1A1A1A;\n    --black: #000000;\n    --white: #FFFFFF;\n    --light-gray: #F5F5F5;\n    --medium-gray: #333333;\n  }\n\n  .reference-hero-section {\n    width: 100%;\n    max-width: 100%;\n    box-sizing: border-box;\n    min-height: 100vh;\n    min-height: 100svh;\n    position: relative;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    overflow: hidden;\n    padding: 100px 24px 100px;\n    text-align: center;\n  }\n\n  .reference-hero-section .mh-hero-bg {\n    position: absolute;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    inset: 0;\n    z-index: 0;\n    background: var(--dark-gray);\n  }\n\n  .reference-hero-section .mh-hero-overlay {\n    position: absolute;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    inset: 0;\n    background: linear-gradient(135deg, rgba(26, 26, 26, 0.75), rgba(0, 0, 0, 0.8));\n    z-index: 1;\n  }\n\n  .reference-hero-section .mh-hero-video {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    opacity: 0.7;\n  }\n\n  .reference-hero-content {\n    position: relative;\n    z-index: 2;\n    max-width: 1000px;\n    width: 100%;\n  }\n\n  .reference-hero-section .section-badge,\n  .reference-hero-section .mh-badge {\n    display: inline-block;\n    padding: 8px 24px;\n    background: var(--primary-gold) !important;\n    color: #000000 !important;\n    -webkit-text-fill-color: #000000 !important;\n    font-family: 'Inter', sans-serif;\n    font-size: 13px;\n    font-weight: 600;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    border-radius: 30px;\n    margin-bottom: 24px;\n    border: none;\n  }\n\n  .reference-hero-section .hero-title,\n  .reference-hero-section .reference-hero-content .hero-title,\n  .reference-hero-section h1,\n  .reference-hero-section h1.hero-title {\n    font-family: 'Poppins', sans-serif;\n    font-size: clamp(36px, 5vw, 64px);\n    font-weight: 700;\n    color: #ffffff !important;\n    -webkit-text-fill-color: #ffffff !important;\n    margin: 0 0 24px 0;\n    letter-spacing: normal;\n    line-height: 1.2;\n  }\n\n  .reference-hero-section .hero-description,\n  .reference-hero-section .reference-hero-content .hero-description,\n  .reference-hero-section p.hero-description {\n    font-family: 'Inter', sans-serif;\n    font-size: clamp(16px, 2vw, 20px);\n    color: rgba(255,255,255,0.9) !important;\n    -webkit-text-fill-color: rgba(255,255,255,0.9) !important;\n    opacity: 1;\n    margin: 0 0 28px 0;\n    line-height: 1.6;\n  }\n\n  .reference-hero-links {\n    display: flex;\n    gap: 16px;\n    justify-content: center;\n    flex-wrap: wrap;\n  }\n\n  .reference-hero-pill {\n    display: inline-block;\n    padding: 18px 48px;\n    background: var(--primary-gold);\n    color: #000000 !important;\n    -webkit-text-fill-color: #000000 !important;\n    font-family: 'Inter', sans-serif;\n    font-size: 18px;\n    font-weight: 600;\n    text-decoration: none;\n    border-radius: 12px;\n    border: none;\n    transition: all 0.3s ease;\n    box-shadow: 0 4px 16px rgba(229, 193, 88, 0.3);\n  }\n\n  .reference-hero-pill:hover {\n    background: var(--secondary-gold);\n    color: #000000 !important;\n    -webkit-text-fill-color: #000000 !important;\n    transform: translateY(-2px);\n    box-shadow: 0 6px 24px rgba(229, 193, 88, 0.4);\n  }\n\n  .reference-hero-pill-secondary {\n    background: transparent !important;\n    color: #ffffff !important;\n    -webkit-text-fill-color: #ffffff !important;\n    border: 2px solid var(--primary-gold);\n    box-shadow: none;\n  }\n\n  .reference-hero-pill-secondary:hover {\n    background: var(--primary-gold) !important;\n    color: #000000 !important;\n    -webkit-text-fill-color: #000000 !important;\n    border-color: var(--primary-gold);\n    transform: translateY(-2px);\n    box-shadow: 0 4px 16px rgba(229, 193, 88, 0.3);\n  }\n\n  .reference-hero-pill-secondary:hover:active {\n    background: var(--secondary-gold) !important;\n  }\n\n  @media (max-width: 768px) {\n    .reference-hero-section {\n      padding: 70px 24px 80px;\n      min-height: 100vh;\n      min-height: 100svh;\n    }\n  }\n\n  .brxe-section {\n    background: transparent !important;\n    padding: 0 !important;\n    margin: 0 !important;\n  }\n  .brxe-container {\n    background: transparent !important;\n    padding: 0 !important;\n    margin: 0 !important;\n    max-width: 100% !important;\n    width: 100% !important;\n  }\n  body {\n    background: #FFFFFF !important;\n  }\n  @media (max-width: 900px) { #brxe-reference_hero_section, #brxe-reference_hero_container { background: #1A1A1A !important; min-height: 100vh; min-height: 100svh; height: auto; max-height: none; overflow: hidden; } #brxe-reference_hero_code { background: transparent !important; padding: 0 !important; margin: 0 !important; height: 100% !important; min-height: 100% !important; position: absolute !important; top: 0 !important; left: 0 !important; right: 0 !important; bottom: 0 !important; } #brxe-reference_hero_container { position: relative !important; } .reference-hero-section { min-height: 100% !important; height: 100% !important; max-height: none !important; overflow: hidden; } #brxe-reference_hero_code .mh-hero-bg, #brxe-reference_hero_code .mh-hero-overlay { top: 0 !important; left: 0 !important; width: 100% !important; min-width: 100% !important; height: 100% !important; min-height: 100% !important; } main#brx-content { background: #1A1A1A !important; } }\n  @media (min-width: 901px) { #brxe-reference_hero_section, #brxe-reference_hero_container { min-height: 100vh !important; min-height: 100svh !important; height: 100svh !important; background: #1A1A1A !important; overflow: hidden; } #brxe-reference_hero_code { height: 100% !important; min-height: 100% !important; } .reference-hero-section, .reference-hero-section .mh-hero-bg, .reference-hero-section .mh-hero-overlay { min-height: 100% !important; height: 100% !important; } }\n</style>",
