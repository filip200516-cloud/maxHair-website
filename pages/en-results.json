    "settings": {
      "code": "<!-- RESULTS CTA SECTION -->\n<section class=\"reference-cta-section\" style=\"background:#F5F5F5 !important;color:#1A1A1A !important;\">\n  <div class=\"reference-cta-content\">\n    <h2 class=\"cta-title\" style=\"color:#1A1A1A !important;\">Want to be the next satisfied client?</h2>\n    <p class=\"cta-description\" style=\"color:#333333 !important;\">Schedule a free consultation and find out how we can help you</p>\n    <div class=\"cta-buttons\">\n      <a href=\"/en-contact\" class=\"btn-primary\">Free consultation</a>\n      <a href=\"/en-home\" class=\"btn-secondary\" style=\"color:#1A1A1A !important;border-color:#1A1A1A !important;\">Back to homepage</a>\n    </div>\n  </div>\n</section>\n\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap');\n\n  :root {\n    --primary-gold: #E5C158;\n    --secondary-gold: #D4AF37;\n    --dark-gray: #1A1A1A;\n    --black: #000000;\n    --white: #FFFFFF;\n    --light-gray: #F5F5F5;\n    --medium-gray: #333333;\n  }\n\n  .reference-cta-section {\n    width: 100%;\n    max-width: 100%;\n    box-sizing: border-box;\n    min-height: 50vh;\n    background: #F5F5F5;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    padding: 100px 80px;\n  }\n\n  .reference-cta-content {\n    max-width: 800px;\n    width: 100%;\n    text-align: center;\n  }\n\n  .reference-cta-section .cta-title {\n    font-family: 'Poppins', sans-serif;\n    font-size: clamp(32px, 4vw, 48px);\n    font-weight: 700;\n    color: #1A1A1A !important;\n    margin: 0 0 24px 0;\n  }\n\n  .reference-cta-section .cta-description {\n    font-family: 'Inter', sans-serif;\n    font-size: clamp(16px, 2vw, 20px);\n    color: #333333 !important;\n    margin: 0 0 40px 0;\n    line-height: 1.6;\n  }\n\n  .reference-cta-section .btn-secondary {\n    color: #1A1A1A !important;\n    border-color: #1A1A1A;\n  }\n\n  .reference-cta-section .btn-secondary:hover {\n    background: #1A1A1A !important;\n    color: #FFFFFF !important;\n  }\n\n  .cta-buttons {\n    display: flex;\n    gap: 24px;\n    justify-content: center;\n    flex-wrap: wrap;\n  }\n\n  .btn-primary {\n    display: inline-block;\n    padding: 18px 48px;\n    background: var(--primary-gold);\n    color: var(--black);\n    font-family: 'Inter', sans-serif;\n    font-size: 18px;\n    font-weight: 600;\n    text-decoration: none;\n    border-radius: 12px;\n    transition: all 0.3s ease;\n    box-shadow: 0 4px 16px rgba(229, 193, 88, 0.3);\n  }\n\n  .btn-primary:hover {\n    background: var(--secondary-gold);\n    transform: translateY(-2px);\n    box-shadow: 0 6px 24px rgba(229, 193, 88, 0.4);\n  }\n\n  .btn-secondary {\n    display: inline-block;\n    padding: 18px 48px;\n    background: transparent;\n    color: var(--white);\n    font-family: 'Inter', sans-serif;\n    font-size: 18px;\n    font-weight: 600;\n    text-decoration: none;\n    border: 2px solid var(--white);\n    border-radius: 12px;\n    transition: all 0.3s ease;\n  }\n\n  .btn-secondary:hover {\n    background: var(--white);\n    color: var(--dark-gray);\n  }\n\n  @media (max-width: 768px) {\n    .reference-cta-section {\n      padding: 60px 24px;\n    }\n\n    .cta-buttons {\n      flex-direction: column;\n      align-items: center;\n    }\n\n    .btn-primary,\n    .btn-secondary {\n      width: 100%;\n      max-width: 300px;\n    }\n  }\n</style>",
