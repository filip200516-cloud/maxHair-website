    "settings": {
      "code": "<!-- RESULTS BEFORE & AFTER SECTION -->\n<section id=\"reference-predpo\" class=\"reference-predpo-section\">\n  <div class=\"reference-predpo-content\">\n    <span class=\"mh-badge\">BEFORE & AFTER</span>\n    <h2 class=\"section-title\">Results of our procedures</h2>\n    <p class=\"section-description\">See the real results of our clients</p>\n    \n    <div class=\"predpo-grid\">\n      <div class=\"predpo-card\">\n        <div class=\"predpo-images\">\n          <div class=\"predpo-before\">\n            <img src=\"https://silver-alligator-496114.hostingersite.com/wp-content/uploads/2026/01/1.jpg\" alt=\"Before transplant - Example 1\">\n            <span class=\"image-label\">BEFORE</span>\n          </div>\n          <div class=\"predpo-after\">\n            <img src=\"https://silver-alligator-496114.hostingersite.com/wp-content/uploads/2026/01/2.jpg\" alt=\"After transplant - Example 1\">\n            <span class=\"image-label\">AFTER</span>\n          </div>\n        </div>\n        <div class=\"predpo-info\">\n          <h3>Example 1</h3>\n          <p>Sapphire FUE | 5500 grafts | Month 12</p>\n        </div>\n      </div>\n\n      <div class=\"predpo-card\">\n        <div class=\"predpo-images\">\n          <div class=\"predpo-before\">\n            <img src=\"https://silver-alligator-496114.hostingersite.com/wp-content/uploads/2026/01/1-1.jpg\" alt=\"Before transplant - Example 2\">\n            <span class=\"image-label\">BEFORE</span>\n          </div>\n          <div class=\"predpo-after\">\n            <img src=\"https://silver-alligator-496114.hostingersite.com/wp-content/uploads/2026/01/2-1.jpg\" alt=\"After transplant - Example 2\">\n            <span class=\"image-label\">AFTER</span>\n          </div>\n        </div>\n        <div class=\"predpo-info\">\n          <h3>Example 2</h3>\n          <p>DHI method | 3850 grafts | Month 9</p>\n        </div>\n      </div>\n\n      <div class=\"predpo-card\">\n        <div class=\"predpo-images\">\n          <div class=\"predpo-before\">\n            <img src=\"https://silver-alligator-496114.hostingersite.com/wp-content/uploads/2026/01/1-2.jpg\" alt=\"Before transplant - Example 3\">\n            <span class=\"image-label\">BEFORE</span>\n          </div>\n          <div class=\"predpo-after\">\n            <img src=\"https://silver-alligator-496114.hostingersite.com/wp-content/uploads/2026/01/2-2.jpg\" alt=\"After transplant - Example 3\">\n            <span class=\"image-label\">AFTER</span>\n          </div>\n        </div>\n        <div class=\"predpo-info\">\n          <h3>Example 3</h3>\n          <p>Sapphire FUE | 4500 grafts | Month 12</p>\n        </div>\n      </div>\n\n      <div class=\"predpo-card\">\n        <div class=\"predpo-images\">\n          <div class=\"predpo-before\">\n            <img src=\"https://silver-alligator-496114.hostingersite.com/wp-content/uploads/2026/01/1-3.jpg\" alt=\"Before transplant - Example 4\">\n            <span class=\"image-label\">BEFORE</span>\n          </div>\n          <div class=\"predpo-after\">\n            <img src=\"https://silver-alligator-496114.hostingersite.com/wp-content/uploads/2026/01/2-3.jpg\" alt=\"After transplant - Example 4\">\n            <span class=\"image-label\">AFTER</span>\n          </div>\n        </div>\n        <div class=\"predpo-info\">\n          <h3>Example 4</h3>\n          <p>Sapphire FUE | 4200 grafts | Month 6</p>\n        </div>\n      </div>\n\n      <div class=\"predpo-card\">\n        <div class=\"predpo-images\">\n          <div class=\"predpo-before\">\n            <img src=\"https://silver-alligator-496114.hostingersite.com/wp-content/uploads/2026/01/1-4.jpg\" alt=\"Before transplant - Example 5\">\n            <span class=\"image-label\">BEFORE</span>\n          </div>\n          <div class=\"predpo-after\">\n            <img src=\"https://silver-alligator-496114.hostingersite.com/wp-content/uploads/2026/01/2-4.jpg\" alt=\"After transplant - Example 5\">\n            <span class=\"image-label\">AFTER</span>\n          </div>\n        </div>\n        <div class=\"predpo-info\">\n          <h3>Example 5</h3>\n          <p>DHI method | 3250 grafts | Month 8</p>\n        </div>\n      </div>\n\n      <div class=\"predpo-card\">\n        <div class=\"predpo-images\">\n          <div class=\"predpo-before\">\n            <img src=\"https://silver-alligator-496114.hostingersite.com/wp-content/uploads/2026/01/1-5.jpg\" alt=\"Before transplant - Example 6\">\n            <span class=\"image-label\">BEFORE</span>\n          </div>\n          <div class=\"predpo-after\">\n            <img src=\"https://silver-alligator-496114.hostingersite.com/wp-content/uploads/2026/01/2-5.jpg\" alt=\"After transplant - Example 6\">\n            <span class=\"image-label\">AFTER</span>\n          </div>\n        </div>\n        <div class=\"predpo-info\">\n          <h3>Example 6</h3>\n          <p>Sapphire FUE | 5000 grafts | Month 5</p>\n        </div>\n      </div>\n\n      <div class=\"predpo-card\">\n        <div class=\"predpo-images\">\n          <div class=\"predpo-before\">\n            <img src=\"https://silver-alligator-496114.hostingersite.com/wp-content/uploads/2026/01/1-6.jpg\" alt=\"Before transplant - Example 7\">\n            <span class=\"image-label\">BEFORE</span>\n          </div>\n          <div class=\"predpo-after\">\n            <img src=\"https://silver-alligator-496114.hostingersite.com/wp-content/uploads/2026/01/2-6.jpg\" alt=\"After transplant - Example 7\">\n            <span class=\"image-label\">AFTER</span>\n          </div>\n        </div>\n        <div class=\"predpo-info\">\n          <h3>Example 7</h3>\n          <p>DHI method (2nd transplant) | 3800 grafts | Month 8</p>\n        </div>\n      </div>\n\n      <div class=\"predpo-card\">\n        <div class=\"predpo-images\">\n          <div class=\"predpo-before\">\n            <img src=\"https://silver-alligator-496114.hostingersite.com/wp-content/uploads/2026/01/1-7.jpg\" alt=\"Before transplant - Example 8\">\n            <span class=\"image-label\">BEFORE</span>\n          </div>\n          <div class=\"predpo-after\">\n            <img src=\"https://silver-alligator-496114.hostingersite.com/wp-content/uploads/2026/01/2-7.jpg\" alt=\"After transplant - Example 8\">\n            <span class=\"image-label\">AFTER</span>\n          </div>\n        </div>\n        <div class=\"predpo-info\">\n          <h3>Example 8</h3>\n          <p>DHI method | 3650 grafts | Month 12</p>\n        </div>\n      </div>\n\n      <div class=\"predpo-card\">\n        <div class=\"predpo-images\">\n          <div class=\"predpo-before\">\n            <img src=\"https://silver-alligator-496114.hostingersite.com/wp-content/uploads/2026/01/1-8.jpg\" alt=\"Before transplant - Example 9\">\n            <span class=\"image-label\">BEFORE</span>\n          </div>\n          <div class=\"predpo-after\">\n            <img src=\"https://silver-alligator-496114.hostingersite.com/wp-content/uploads/2026/01/2-8.jpg\" alt=\"After transplant - Example 9\">\n            <span class=\"image-label\">AFTER</span>\n          </div>\n        </div>\n        <div class=\"predpo-info\">\n          <h3>Example 9</h3>\n          <p>Sapphire FUE | 2850 grafts | Month 7</p>\n        </div>\n      </div>\n\n      <div class=\"predpo-card\">\n        <div class=\"predpo-images\">\n          <div class=\"predpo-before\">\n            <img src=\"https://silver-alligator-496114.hostingersite.com/wp-content/uploads/2026/01/1-9.jpg\" alt=\"Before transplant - Example 10\">\n            <span class=\"image-label\">BEFORE</span>\n          </div>\n          <div class=\"predpo-after\">\n            <img src=\"https://silver-alligator-496114.hostingersite.com/wp-content/uploads/2026/01/2-9.jpg\" alt=\"After transplant - Example 10\">\n            <span class=\"image-label\">AFTER</span>\n          </div>\n        </div>\n        <div class=\"predpo-info\">\n          <h3>Example 10</h3>\n          <p>Sapphire FUE | 4600 grafts | Month 6</p>\n        </div>\n      </div>\n\n      <div class=\"predpo-card\">\n        <div class=\"predpo-images\">\n          <div class=\"predpo-before\">\n            <img src=\"https://silver-alligator-496114.hostingersite.com/wp-content/uploads/2026/01/1-10.jpg\" alt=\"Before transplant - Example 11\">\n            <span class=\"image-label\">BEFORE</span>\n          </div>\n          <div class=\"predpo-after\">\n            <img src=\"https://silver-alligator-496114.hostingersite.com/wp-content/uploads/2026/01/2-10.jpg\" alt=\"After transplant - Example 11\">\n            <span class=\"image-label\">AFTER</span>\n          </div>\n        </div>\n        <div class=\"predpo-info\">\n          <h3>Example 11</h3>\n          <p>Sapphire FUE | 5500 grafts | Month 12</p>\n        </div>\n      </div>\n\n      <div class=\"predpo-card\">\n        <div class=\"predpo-images\">\n          <div class=\"predpo-before\">\n            <img src=\"https://silver-alligator-496114.hostingersite.com/wp-content/uploads/2026/01/1-11.jpg\" alt=\"Before transplant - Example 12\">\n            <span class=\"image-label\">BEFORE</span>\n          </div>\n          <div class=\"predpo-after\">\n            <img src=\"https://silver-alligator-496114.hostingersite.com/wp-content/uploads/2026/01/2-11.jpg\" alt=\"After transplant - Example 12\">\n            <span class=\"image-label\">AFTER</span>\n          </div>\n        </div>\n        <div class=\"predpo-info\">\n          <h3>Example 12</h3>\n          <p>DHI method | 3200 grafts | Month 8</p>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap');\n\n  :root {\n    --primary-gold: #E5C158;\n    --secondary-gold: #D4AF37;\n    --dark-gray: #1A1A1A;\n    --black: #000000;\n    --white: #FFFFFF;\n    --light-gray: #F5F5F5;\n    --medium-gray: #333333;\n  }\n\n  .reference-predpo-section {\n    width: 100%;\n    max-width: 100%;\n    box-sizing: border-box;\n    min-height: auto;\n    background: var(--white);\n    padding: 100px 80px;\n  }\n\n  .reference-predpo-content {\n    max-width: 1400px;\n    width: 100%;\n    margin: 0 auto;\n    text-align: center;\n  }\n\n  .reference-predpo-section .section-badge,\n  .reference-predpo-section .mh-badge {\n    display: inline-block;\n    padding: 8px 24px;\n    background: var(--primary-gold) !important;\n    color: #000000 !important;\n    -webkit-text-fill-color: #000000 !important;\n    font-family: 'Inter', sans-serif;\n    font-size: 13px;\n    font-weight: 600;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    margin-bottom: 24px;\n    border-radius: 30px;\n    border: none;\n  }\n\n  .reference-predpo-section .section-title {\n    font-family: 'Poppins', sans-serif;\n    font-size: clamp(32px, 4vw, 48px);\n    font-weight: 700;\n    color: var(--dark-gray);\n    margin: 0 0 16px 0;\n  }\n\n  .reference-predpo-section .section-description {\n    font-family: 'Inter', sans-serif;\n    font-size: clamp(16px, 2vw, 20px);\n    color: var(--dark-gray);\n    opacity: 0.7;\n    margin: 0 0 40px 0;\n    text-align: center;\n  }\n\n  .reference-predpo-section .predpo-grid {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 32px;\n  }\n\n  .reference-predpo-section .predpo-card {\n    background: var(--light-gray);\n    border-radius: 16px;\n    overflow: hidden;\n    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);\n    transition: all 0.3s ease;\n  }\n\n  .reference-predpo-section .predpo-card:hover {\n    transform: translateY(-8px);\n    box-shadow: 0 12px 40px rgba(229, 193, 88, 0.3);\n  }\n\n  .reference-predpo-section .predpo-images {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 2px;\n    background: var(--light-gray);\n  }\n\n  .reference-predpo-section .predpo-before,\n  .reference-predpo-section .predpo-after {\n    position: relative;\n    height: 280px;\n    overflow: hidden;\n  }\n\n  .reference-predpo-section .predpo-before img,\n  .reference-predpo-section .predpo-after img {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    display: block;\n    transition: transform 0.3s ease;\n  }\n\n  .reference-predpo-section .predpo-card:hover .predpo-before img,\n  .reference-predpo-section .predpo-card:hover .predpo-after img {\n    transform: scale(1.05);\n  }\n\n  .reference-predpo-section .image-label {\n    position: absolute;\n    bottom: 12px;\n    left: 50%;\n    transform: translateX(-50%);\n    background: rgba(0, 0, 0, 0.75);\n    color: var(--white);\n    padding: 6px 16px;\n    border-radius: 20px;\n    font-family: 'Inter', sans-serif;\n    font-size: 11px;\n    font-weight: 700;\n    letter-spacing: 1.5px;\n    text-transform: uppercase;\n  }\n\n  .reference-predpo-section .predpo-info {\n    padding: 20px 24px;\n    text-align: center;\n    background: var(--light-gray);\n  }\n\n  .reference-predpo-section .predpo-info h3 {\n    font-family: 'Poppins', sans-serif;\n    font-size: 18px;\n    font-weight: 700;\n    color: var(--dark-gray);\n    margin: 0 0 6px 0;\n  }\n\n  .reference-predpo-section .predpo-info p {\n    font-family: 'Inter', sans-serif;\n    font-size: 14px;\n    color: var(--dark-gray);\n    opacity: 0.6;\n    margin: 0;\n  }\n\n  @media (max-width: 1200px) {\n    .reference-predpo-section .predpo-grid {\n      grid-template-columns: repeat(2, 1fr);\n    }\n  }\n\n  @media (max-width: 768px) {\n    .reference-predpo-section {\n      padding: 60px 24px;\n    }\n\n    .reference-predpo-section .predpo-grid {\n      grid-template-columns: 1fr;\n    }\n\n    .reference-predpo-section .predpo-before,\n    .reference-predpo-section .predpo-after {\n      height: 200px;\n    }\n  }\n</style>",
