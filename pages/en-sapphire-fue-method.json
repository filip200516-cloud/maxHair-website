    "settings": {
      "code": "<script>(function(){var sectionId='brxe-sapphire_hero_section';if(!window.matchMedia('(max-width: 900px)').matches)return;function getSvhPx(){var d=document.createElement('div');d.style.cssText='height:100svh;position:absolute;top:-9999px;left:0;visibility:hidden;';document.body.appendChild(d);var h=d.offsetHeight;document.body.removeChild(d);return h;}function lockHero(){var section=document.getElementById(sectionId);var container=section?section.querySelector('.brxe-container'):null;var h=getSvhPx();if(section){section.style.height=h+'px';section.style.minHeight=h+'px';section.style.maxHeight=h+'px';}if(container){container.style.height=h+'px';container.style.minHeight=h+'px';container.style.maxHeight=h+'px';}}if(document.body)lockHero();if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',lockHero);else setTimeout(lockHero,0);setTimeout(lockHero,100);})();</script>\n<script>(function(){var d=document;if(!window.matchMedia('(max-width: 900px)').matches)return;function fix(){var section=d.getElementById('brxe-sapphire_hero_section');var container=d.getElementById('brxe-sapphire_hero_container');var code=d.getElementById('brxe-sapphire_hero_code');if(section){section.style.setProperty('background','#1A1A1A','important');section.style.setProperty('padding','0','important');section.style.setProperty('margin','0','important');}if(container){container.style.setProperty('background','#1A1A1A','important');container.style.setProperty('padding','0','important');container.style.setProperty('margin','0','important');}if(code){code.style.setProperty('background','transparent','important');code.style.setProperty('padding','0','important');code.style.setProperty('margin','0','important');}}function run(){fix();var t=0;var iv=setInterval(function(){fix();t+=200;if(t>=1500)clearInterval(iv);},200);}if(d.readyState==='loading')d.addEventListener('DOMContentLoaded',run);else run();})();</script>\n<!-- SAPPHIRE FUE HERO SECTION -->\n<section class=\"sapphire-hero-section\">\n  <div class=\"sapphire-hero-bg-image\" role=\"img\" aria-hidden=\"true\"></div>\n  <div class=\"sapphire-hero-content\">\n    <span class=\"mh-badge\">METHODS</span>\n    <h1 class=\"hero-title\" style=\"color: #ffffff !important;\">Sapphire FUE<br/>Sapphire Transplantation</h1>\n    <p class=\"hero-description\" style=\"color: rgba(255,255,255,0.9) !important;\">A gentle hair transplant method using sapphire blades. Suitable for larger areas and higher graft counts.</p>\n    <div class=\"hero-cta-group\">\n      <a href=\"/en-contact\" class=\"btn-primary\">Free consultation</a>\n      <a href=\"/en-home#pricing\" class=\"btn-secondary\">Check price</a>\n    </div>\n  </div>\n</section>\n\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap');\n\n  :root {\n    --primary-gold: #E5C158;\n    --secondary-gold: #D4AF37;\n    --dark-gray: #1A1A1A;\n    --black: #000000;\n    --white: #FFFFFF;\n    --light-gray: #F5F5F5;\n    --medium-gray: #333333;\n  }\n\n  .sapphire-hero-section {\n    width: 100%;\n    max-width: 100%;\n    box-sizing: border-box;\n    min-height: 100vh; min-height: 100svh;\n    background: linear-gradient(135deg, rgba(90, 69, 44, 0.75) 0%, rgba(0, 0, 0, 0.8) 100%);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    padding: clamp(60px, 10vh, 120px) clamp(20px, 5vw, 80px);\n    position: relative;\n    overflow: hidden;\n  }\n\n  .sapphire-hero-bg-image {\n    position: absolute;\n    top: 0;\n    left: 0;\n    right: 0;\n    bottom: 0;\n    background-image: url(https://maxhair.cz/wp-content/uploads/2026/03/hero-muzi-3-1-scaled.jpg);\n    background-size: cover;\n    background-position: center;\n    z-index: 0;\n    opacity: 0.4;\n  }\n\n  .sapphire-hero-section::after {\n    content: '';\n    position: absolute;\n    top: 0;\n    left: 0;\n    right: 0;\n    bottom: 0;\n    background: linear-gradient(135deg, rgba(90, 69, 44, 0.7) 0%, rgba(0, 0, 0, 0.75) 100%);\n    z-index: 0;\n    pointer-events: none;\n  }\n\n  .sapphire-hero-content {\n    max-width: 1200px;\n    width: 100%;\n    text-align: center;\n    position: relative;\n    z-index: 2;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n  }\n\n  .sapphire-hero-section .mh-badge,\n  .sapphire-hero-content .mh-badge {\n    display: inline-block;\n    padding: 8px 24px;\n    background: var(--primary-gold) !important;\n    color: var(--black) !important;\n    -webkit-text-fill-color: var(--black) !important;\n    font-family: 'Inter', sans-serif;\n    font-size: 13px;\n    font-weight: 600;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    border-radius: 30px;\n    margin-bottom: 24px;\n    border: none;\n  }\n\n  .mh-badge {\n    display: inline-block;\n    padding: 8px 24px;\n    background: var(--primary-gold) !important;\n    color: var(--black) !important;\n    font-family: 'Inter', sans-serif;\n    font-size: 13px;\n    font-weight: 600;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    border-radius: 30px;\n    margin-bottom: 20px;\n    border: none;\n  }\n\n  .hero-title {\n    font-family: 'Poppins', sans-serif;\n    font-size: clamp(42px, 6vw, 72px);\n    font-weight: 700;\n    color: var(--white);\n    margin: 0 0 24px 0;\n    letter-spacing: normal;\n    line-height: 1.2;\n  }\n\n  .hero-description {\n    font-family: 'Inter', sans-serif;\n    font-size: clamp(18px, 2.5vw, 24px);\n    color: rgba(255, 255, 255, 0.9);\n    margin: 0 0 48px 0;\n    line-height: 1.6;\n    max-width: 800px;\n    margin-left: auto;\n    margin-right: auto;\n  }\n\n  .hero-cta-group {\n    display: flex;\n    gap: 20px;\n    justify-content: center;\n    flex-wrap: wrap;\n  }\n\n  .btn-primary {\n    display: inline-block;\n    padding: 18px 40px;\n    background: var(--primary-gold);\n    color: var(--black);\n    font-family: 'Inter', sans-serif;\n    font-size: 16px;\n    font-weight: 600;\n    text-decoration: none;\n    border-radius: 10px;\n    transition: all 0.3s ease;\n    box-shadow: 0 6px 24px rgba(229, 193, 88, 0.4);\n  }\n\n  .btn-primary:hover {\n    background: var(--secondary-gold);\n    transform: translateY(-3px);\n    box-shadow: 0 10px 35px rgba(229, 193, 88, 0.5);\n  }\n\n  .btn-secondary {\n    display: inline-block;\n    padding: 18px 40px;\n    background: transparent;\n    color: var(--white);\n    font-family: 'Inter', sans-serif;\n    font-size: 16px;\n    font-weight: 600;\n    text-decoration: none;\n    border: 2px solid var(--white);\n    border-radius: 10px;\n    transition: all 0.3s ease;\n  }\n\n  .btn-secondary:hover {\n    background: var(--white);\n    color: var(--black);\n    transform: translateY(-3px);\n  }\n\n  @media (max-width: 768px) {\n    .sapphire-hero-section {\n      padding: calc(var(--mh-header-height,64px) + 12px) 20px 32px;\n      min-height: 100vh;\n      min-height: 100svh;\n    }\n    .sapphire-hero-section .mh-badge { font-size: 11px; padding: 6px 14px; margin-bottom: 12px; }\n    .sapphire-hero-section .hero-title { font-size: clamp(26px, 6vw, 32px); margin-bottom: 12px; }\n    .sapphire-hero-section .hero-description { font-size: 14px; line-height: 1.45; margin-bottom: 28px; }\n    .sapphire-hero-section .hero-cta-group { gap: 12px; flex-direction: column; }\n    .sapphire-hero-section .btn-primary, .sapphire-hero-section .btn-secondary { padding: 12px 24px; font-size: 14px; }\n  }\n  @media (max-width: 480px) {\n    .sapphire-hero-section { padding: calc(var(--mh-header-height,64px) + 8px) 16px 24px; }\n    .sapphire-hero-section .hero-title { font-size: 24px; margin-bottom: 10px; }\n    .sapphire-hero-section .hero-description { font-size: 13px; margin-bottom: 20px; }\n    .sapphire-hero-section .btn-primary, .sapphire-hero-section .btn-secondary { padding: 10px 20px; font-size: 13px; }\n  }\n  @media (max-width: 900px) {\n    #brxe-sapphire_hero_section,\n    #brxe-sapphire_hero_container { background: #1A1A1A !important; min-height: 100vh; min-height: 100svh; min-height: calc(100svh + 80px); max-height: none; height: auto; overflow: hidden; }\n    main#brx-content { background: #1A1A1A !important; }\n    #brxe-sapphire_hero_container .brxe-code { min-height: 100%; height: 100%; padding: 0 !important; margin: 0 !important; background: transparent !important; position: absolute !important; top: 0 !important; left: 0 !important; right: 0 !important; bottom: 0 !important; }\n    #brxe-sapphire_hero_code { background: transparent !important; padding: 0 !important; margin: 0 !important; height: 100% !important; min-height: 100% !important; position: absolute !important; top: 0 !important; left: 0 !important; right: 0 !important; bottom: 0 !important; }\n    #brxe-sapphire_hero_container { position: relative !important; }\n    .sapphire-hero-section { min-height: 100% !important; height: 100% !important; max-height: none !important; overflow: hidden; }\n    #brxe-sapphire_hero_section { margin-bottom: -120px !important; padding-bottom: 0 !important; }\n    #brxe-sapphire_co_section { margin-top: -120px !important; padding-top: 120px !important; }\n  }\n  @media (min-width: 901px) { #brxe-sapphire_hero_section, #brxe-sapphire_hero_container { min-height: 100vh !important; min-height: 100svh !important; height: 100svh !important; background: #1A1A1A !important; overflow: hidden; } #brxe-sapphire_hero_code { height: 100% !important; min-height: 100% !important; } .sapphire-hero-section, .sapphire-hero-content { min-height: 100% !important; height: 100% !important; } }\n  .sapphire-hero-section .hero-title { color: #ffffff !important; }\n  .sapphire-hero-section .hero-description { color: rgba(255,255,255,0.9) !important; }\n</style>",
