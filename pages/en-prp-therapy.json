    "settings": {
      "code": "<script>(function(){var sectionId='brxe-prp_hero_section';function getSvhPx(){var d=document.createElement('div');d.style.cssText='height:100svh;position:absolute;top:-9999px;left:0;visibility:hidden;';document.body.appendChild(d);var h=d.offsetHeight;document.body.removeChild(d);return h;}function lockHero(){var section=document.getElementById(sectionId);var container=section?section.querySelector('.brxe-container'):null;var h=getSvhPx();if(section){section.style.height=h+'px';section.style.minHeight=h+'px';section.style.maxHeight=h+'px';}if(container){container.style.height=h+'px';container.style.minHeight=h+'px';container.style.maxHeight=h+'px';}}if(!window.matchMedia('(max-width: 900px)').matches)return;if(document.body)lockHero();if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',lockHero);else setTimeout(lockHero,0);setTimeout(lockHero,100);})();</script>\n<script>(function(){var d=document;if(!window.matchMedia('(max-width: 900px)').matches)return;function fix(){var section=d.getElementById('brxe-prp_hero_section');var container=d.getElementById('brxe-prp_hero_container');var code=d.getElementById('brxe-prp_hero_code');if(section){section.style.setProperty('background','#1A1A1A','important');section.style.setProperty('padding','0','important');section.style.setProperty('margin','0','important');}if(container){container.style.setProperty('background','#1A1A1A','important');container.style.setProperty('padding','0','important');container.style.setProperty('margin','0','important');}if(code){code.style.setProperty('background','transparent','important');code.style.setProperty('padding','0','important');code.style.setProperty('margin','0','important');}}function run(){fix();var t=0;var iv=setInterval(function(){fix();t+=200;if(t>=1500)clearInterval(iv);},200);}if(d.readyState==='loading')d.addEventListener('DOMContentLoaded',run);else run();})();</script>\n<!-- PRP THERAPY HERO -->\n<section class=\"prp-hero-section\">\n  <div class=\"hero-bg-image\" role=\"img\" aria-hidden=\"true\"></div>\n  <div class=\"hero-overlay\"></div>\n  <div class=\"prp-hero-content\">\n    <span class=\"mh-badge\">SERVICE</span>\n    <h1 class=\"hero-title\" style=\"color: #ffffff !important;\">PRP Therapy<br/>Platelet-Rich Plasma</h1>\n    <p class=\"hero-description\" style=\"color: rgba(255,255,255,0.9) !important;\">Natural support for hair growth and density using your own blood plasma.</p>\n    <div class=\"hero-price\">\n      <span class=\"hero-price-text\">Included in Transplant Price</span>\n    </div>\n    <div class=\"hero-cta-group\">\n      <a href=\"/en-contact\" class=\"btn-primary\">Free consultation</a>\n      <a href=\"/en-home#pricing\" class=\"btn-secondary\">Check price</a>\n    </div>\n  </div>\n</section>\n\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap');\n\n  :root {\n    --primary-gold: #E5C158;\n    --secondary-gold: #A67C00;\n    --dark-gray: #1A1A1A;\n    --black: #000000;\n    --white: #FFFFFF;\n    --light-gray: #F5F5F5;\n    --medium-gray: #CCCCCC;\n  }\n\n  .prp-hero-section {\n    width: 100%;\n    max-width: 100%;\n    box-sizing: border-box;\n    min-height: 100vh; min-height: 100svh;\n    min-height: 100%; height: 100%;\n    position: relative;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    overflow: hidden;\n  }\n\n  .hero-bg-image {\n    position: absolute;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    min-height: 100%;\n    background-image: url(https://maxhair.cz/wp-content/uploads/2026/03/hero-zeny-1-1-scaled.jpg);\n    background-size: cover;\n    background-position: center;\n    z-index: 1;\n  }\n\n  .hero-overlay {\n    position: absolute;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    min-height: 100%;\n    background: linear-gradient(135deg, rgba(90, 69, 44, 0.85) 0%, rgba(0, 0, 0, 0.85) 100%);\n    z-index: 2;\n  }\n\n  .prp-hero-content {\n    position: relative;\n    z-index: 3;\n    max-width: 1200px;\n    width: 100%;\n    padding: 0 80px;\n    text-align: center;\n  }\n\n  .prp-hero-section .mh-badge,\n  .prp-hero-content .mh-badge {\n    display: inline-block;\n    padding: 8px 24px;\n    background: var(--primary-gold) !important;\n    color: var(--black) !important;\n    -webkit-text-fill-color: var(--black) !important;\n    font-family: 'Inter', sans-serif;\n    font-size: 13px;\n    font-weight: 600;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    border-radius: 30px;\n    margin-bottom: 24px;\n    border: none;\n  }\n\n  .mh-badge {\n    display: inline-block;\n    padding: 8px 24px;\n    background: var(--primary-gold) !important;\n    color: var(--black) !important;\n    font-family: 'Inter', sans-serif;\n    font-size: 13px;\n    font-weight: 600;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    border-radius: 30px;\n    margin-bottom: 20px;\n    border: none;\n  }\n\n  .hero-title {\n    font-family: 'Poppins', sans-serif;\n    font-size: clamp(42px, 6vw, 72px);\n    font-weight: 700;\n    color: var(--white);\n    margin: 0 0 24px 0;\n    letter-spacing: normal;\n    line-height: 1.2;\n  }\n\n  .hero-description {\n    font-family: 'Inter', sans-serif;\n    font-size: clamp(18px, 2.5vw, 24px);\n    color: rgba(255, 255, 255, 0.9);\n    margin: 0 0 40px 0;\n    line-height: 1.6;\n    max-width: 800px;\n    margin-left: auto;\n    margin-right: auto;\n  }\n\n  .hero-price {\n    display: flex;\n    flex-direction: row;\n    flex-wrap: wrap;\n    align-items: center;\n    justify-content: center;\n    gap: 0.35em;\n    margin-bottom: 48px;\n  }\n\n  .prp-hero-section .hero-price-text {\n    font-family: 'Inter', sans-serif;\n    font-size: clamp(16px, 2.2vw, 22px);\n    font-weight: 600;\n    color: var(--white);\n    text-transform: uppercase;\n    letter-spacing: 2px;\n  }\n\n  .price-note {\n    font-family: 'Inter', sans-serif;\n    font-size: 14px;\n    color: rgba(255, 255, 255, 0.7);\n  }\n\n  .hero-cta-group {\n    display: flex;\n    gap: 20px;\n    justify-content: center;\n    flex-wrap: wrap;\n  }\n\n  .btn-primary {\n    display: inline-block;\n    padding: 18px 40px;\n    background: var(--primary-gold);\n    color: var(--black);\n    font-family: 'Inter', sans-serif;\n    font-size: 16px;\n    font-weight: 600;\n    text-decoration: none;\n    border-radius: 10px;\n    transition: all 0.3s ease;\n    box-shadow: 0 6px 24px rgba(229, 193, 88, 0.4);\n  }\n\n  .btn-primary:hover {\n    background: var(--secondary-gold);\n    transform: translateY(-3px);\n    box-shadow: 0 10px 35px rgba(229, 193, 88, 0.5);\n  }\n\n  .btn-secondary {\n    display: inline-block;\n    padding: 18px 40px;\n    background: transparent;\n    color: var(--white);\n    font-family: 'Inter', sans-serif;\n    font-size: 16px;\n    font-weight: 600;\n    text-decoration: none;\n    border: 2px solid var(--white);\n    border-radius: 10px;\n    transition: all 0.3s ease;\n  }\n\n  .btn-secondary:hover {\n    background: var(--white);\n    color: var(--black);\n    transform: translateY(-3px);\n  }\n\n  @media (max-width: 900px) {\n    #brxe-prp_hero_section,\n    #brxe-prp_hero_container { background: #1A1A1A !important; min-height: 100vh; min-height: 100svh; min-height: calc(100svh + 80px); max-height: none; height: auto; overflow: hidden; }\n    main#brx-content { background: #1A1A1A !important; }\n    #brxe-prp_hero_container .brxe-code { min-height: 100%; height: 100%; padding: 0 !important; margin: 0 !important; background: transparent !important; position: absolute !important; top: 0 !important; left: 0 !important; right: 0 !important; bottom: 0 !important; }\n    #brxe-prp_hero_code { background: transparent !important; padding: 0 !important; margin: 0 !important; height: 100% !important; min-height: 100% !important; position: absolute !important; top: 0 !important; left: 0 !important; right: 0 !important; bottom: 0 !important; }\n    #brxe-prp_hero_container { position: relative !important; }\n    .prp-hero-section { min-height: 100% !important; height: 100% !important; max-height: none !important; overflow: hidden; }\n    #brxe-prp_hero_code .hero-bg-image,\n    #brxe-prp_hero_code .hero-overlay { min-height: 100% !important; height: 100% !important; }\n    #brxe-prp_hero_section { margin-bottom: -120px !important; padding-bottom: 0 !important; }\n    #brxe-prp_problem_section { margin-top: -120px !important; padding-top: 120px !important; }\n  }\n  @media (min-width: 901px) { #brxe-prp_hero_section, #brxe-prp_hero_container { min-height: 100vh !important; min-height: 100svh !important; height: 100svh !important; background: #1A1A1A !important; overflow: hidden; } #brxe-prp_hero_code { height: 100% !important; min-height: 100% !important; } .prp-hero-section, #brxe-prp_hero_code .hero-bg-image, #brxe-prp_hero_code .hero-overlay { min-height: 100% !important; height: 100% !important; } }\n  @media (max-width: 768px) {\n    .prp-hero-content { padding: calc(var(--mh-header-height,64px) + 12px) 20px 24px; }\n    .prp-hero-section { min-height: 100vh; min-height: 100svh; }\n    .prp-hero-section .mh-badge { font-size: 11px; padding: 6px 14px; margin-bottom: 12px; }\n    .prp-hero-section .hero-title { font-size: clamp(26px, 6vw, 32px); margin-bottom: 12px; }\n    .prp-hero-section .hero-description { font-size: 14px; line-height: 1.45; margin-bottom: 20px; }\n    .prp-hero-section .hero-price { margin-bottom: 24px; }\n    .prp-hero-section .hero-price-text { font-size: 18px; }\n    .prp-hero-section .price-note { font-size: 12px; }\n    .prp-hero-section .hero-cta-group { gap: 12px; flex-direction: column; }\n    .prp-hero-section .btn-primary, .prp-hero-section .btn-secondary { padding: 12px 24px; font-size: 14px; }\n  }\n  @media (max-width: 480px) {\n    .prp-hero-content { padding: calc(var(--mh-header-height,64px) + 8px) 16px 16px; }\n    .prp-hero-section .hero-title { font-size: 24px; margin-bottom: 10px; }\n    .prp-hero-section .hero-description { font-size: 13px; margin-bottom: 14px; }\n    .prp-hero-section .hero-price { margin-bottom: 16px; }\n    .prp-hero-section .hero-price-text { font-size: 16px; }\n    .prp-hero-section .price-note { font-size: 11px; }\n    .prp-hero-section .btn-primary, .prp-hero-section .btn-secondary { padding: 10px 20px; font-size: 13px; }\n  }\n\n  /* Hero text vždy světlý (bílý) na tmavém pozadí */\n  .prp-hero-section .hero-title,\n  .prp-hero-section .hero-price-text,\n  .prp-hero-section .price-note { color: #ffffff !important; }\n  .prp-hero-section .hero-description { color: rgba(255,255,255,0.9) !important; }\n</style>",
